{
  "name": "monochrome-player",
  "version": "1.0.0",
  "description": "Desktop player for Monochrome music",
  "author": "Monochrome Player <monochrome-player@users.noreply.github.com>",
  "homepage": "https://github.com/kmmiio99o/Player",
  "main": "dist-electron/main.js",
  "scripts": {
    "build:ts": "tsc",
    "start": "tsc && electron .",
    "build": "tsc && electron-builder"
  },
  "dependencies": {
    "discord-rpc": "^4.0.1"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "typescript": "^7.0.2"
  },
  "build": {
    "appId": "tf.monochrome.player",
    "productName": "Monochrome Player",
    "files": [
      "dist-electron/**/*.js",
      "dist-electron/**/*.json",
      "assets/**/*"
    ],
    "extraResources": [],
    "linux": {
      "target": ["AppImage", "deb", "rpm", "pacman"],
      "category": "Audio",
      "icon": "assets/icon.png",
      "maintainer": "kmmiio99o <kmmiio99o@users.noreply.github.com>",
      "desktopName": "Monochrome Player",
      "synopsis": "Desktop player for Monochrome music",
      "description": "A minimalist desktop wrapper for monochrome.tf with Discord Rich Presence, tray controls, and media keys.",
      "publish": null
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.music",
      "icon": "assets/icon.png",
      "darkModeSupport": true
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
