{
  "name": "monochrome-player",
  "version": "1.1.0",
  "description": "Desktop player for Monochrome music",
  "author": "Monochrome Player <monochrome-player@users.noreply.github.com>",
  "homepage": "https://github.com/kmmiio99o/Monochrome-PC",
  "main": "dist-electron/main.js",
  "scripts": {
    "sync-version": "bun scripts/sync-version.ts",
    "build:ts": "tsc",
    "start": "electron .",
    "build": "tsc && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc && eslint .",
    "validate": "prettier --check . && tsc && eslint ."
  },
  "dependencies": {
    "discord-rpc": "^4.0.1",
    "punycode": "^2.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/discord-rpc": "^4.0.11",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "build": {
    "appId": "tf.monochrome.player",
    "productName": "Monochrome Player",
    "files": [
      "dist-electron/**/*.js",
      "dist-electron/**/*.json",
      "assets/**/*"
    ],
    "extraResources": [],
    "linux": {
      "target": [
        "deb",
        "rpm",
        "AppImage"
      ],
      "category": "Audio",
      "icon": "assets/icon.png",
      "maintainer": "kmmiio99o <kmmiio99o@users.noreply.github.com>"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "assets/icon.png",
      "darkModeSupport": true
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "publish": null,
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "trustedDependencies": [
    "register-scheme"
  ]
}
